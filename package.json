{
  "name": "orbit-ai-habit-tracker",
  "version": "1.0.0",
  "description": "Full-stack AI Habit Tracker",
  "scripts": {
    "setup": "npm install && npm install --prefix backend && npm install --prefix frontend/app",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend/app",
    "orbit": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
